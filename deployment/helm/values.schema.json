{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "allOf": [
    {
      "if": {
        "properties": {
          "postgres": {
            "type": "object",
            "properties": {
              "enabled": {
                "const": false
              }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "externalDatabase": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string",
                "minLength": 1
              },
              "existingSecret": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": ["host", "existingSecret"]
          }
        },
        "required": ["externalDatabase"]
      }
    }
  ],
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "cognee": {
      "type": "object",
      "properties": {
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "image": {
          "type": "string",
          "minLength": 1
        },
        "imagePullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "backendAccessControl": {
          "type": "boolean"
        },
        "service": {
          "$ref": "#/definitions/service"
        },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": {
              "type": "boolean"
            },
            "annotations": {
              "type": "object"
            },
            "name": {
              "type": "string"
            }
          }
        },
        "podAnnotations": {
          "type": "object"
        },
        "podSecurityContext": {
          "type": "object"
        },
        "securityContext": {
          "type": "object"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "secrets": {
          "type": "object",
          "properties": {
            "existingSecret": {
              "type": "string"
            },
            "llmApiKeyKey": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "probes": {
          "type": "object"
        },
        "resources": {
          "type": "object"
        },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "minReplicas": {
              "type": "integer",
              "minimum": 1
            },
            "maxReplicas": {
              "type": "integer",
              "minimum": 1
            },
            "targetCPUUtilizationPercentage": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "podDisruptionBudget": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "minAvailable": {
              "type": ["integer", "string"]
            }
          }
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "existingClaim": {
              "type": "string"
            },
            "storageClassName": {
              "type": "string"
            },
            "accessModes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "size": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "image": {
          "type": "string",
          "minLength": 1
        },
        "imagePullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "service": {
          "$ref": "#/definitions/service"
        },
        "auth": {
          "type": "object",
          "properties": {
            "existingSecret": {
              "type": "string"
            },
            "username": {
              "type": "string",
              "minLength": 1
            },
            "database": {
              "type": "string",
              "minLength": 1
            },
            "usernameKey": {
              "type": "string",
              "minLength": 1
            },
            "passwordKey": {
              "type": "string",
              "minLength": 1
            },
            "databaseKey": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "env": {
          "type": "object",
          "properties": {
            "PGDATA": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "storage": {
          "type": "string",
          "minLength": 1
        },
        "podAnnotations": {
          "type": "object"
        },
        "podSecurityContext": {
          "type": "object"
        },
        "securityContext": {
          "type": "object"
        },
        "probes": {
          "type": "object"
        },
        "resources": {
          "type": "object"
        }
      }
    },
    "externalDatabase": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "existingSecret": {
          "type": "string"
        },
        "usernameKey": {
          "type": "string",
          "minLength": 1
        },
        "passwordKey": {
          "type": "string",
          "minLength": 1
        },
        "databaseKey": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "type": "object"
        },
        "hosts": {
          "type": "array"
        },
        "tls": {
          "type": "array"
        }
      }
    },
    "tests": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "image": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "definitions": {
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    }
  }
}
