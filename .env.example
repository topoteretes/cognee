# Cognee Configuration — Copy this to .env and fill in your keys
# Get a free Gemini key at: aistudio.google.com

LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.0-flash
LLM_API_KEY=your_gemini_api_key_here

EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-2
EMBEDDING_API_KEY=your_gemini_api_key_here

ENABLE_BACKEND_ACCESS_CONTROL=false
COGNEE_SKIP_CONNECTION_TEST=true

# Optional: OpenAI alternative
# LLM_PROVIDER=openai
# LLM_MODEL=openai/gpt-4o-mini
# LLM_API_KEY=your_openai_key_here
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_API_KEY=your_openai_key_here
