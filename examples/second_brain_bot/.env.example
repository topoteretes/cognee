# Copy to .env and fill in your key. The .env is gitignored; never commit a real key.
#
# This bot was validated against a Groq LLM plus local fastembed embeddings, so a
# real run needs no embedding API key and no embedding rate limits.

# --- LLM: Groq via cognee's custom (OpenAI-compatible) provider ---
LLM_PROVIDER="custom"
LLM_MODEL="groq/llama-3.3-70b-versatile"
LLM_API_KEY="gsk_your_groq_key_here"
# Do NOT set LLM_ENDPOINT; the groq/ model prefix sets the base URL.

# --- Embeddings: local fastembed (no API, offline) ---
# Needs: pip install fastembed
EMBEDDING_PROVIDER="fastembed"
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"
EMBEDDING_DIMENSIONS=384

# The two cognee knobs below are also forced in config.py (set before import),
# so you do not strictly need them here, but they are documented for clarity:
# ENABLE_BACKEND_ACCESS_CONTROL=false   single-user: no auth, one shared store
# CACHING=false                         disable session-memory side calls
