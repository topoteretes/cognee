# LLM (Cognee uses this for cognify + the bot uses it for answers)
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
LLM_PROVIDER=openai

# GitHub — personal access token with public repo read access
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Docs repo containing Mintlify MDX files
DOCS_REPO_OWNER=topoteretes
DOCS_REPO_NAME=cognee-docs
DOCS_REPO_BRANCH=main

# Public code repo — GitHub issues source
CODE_REPO_OWNER=topoteretes
CODE_REPO_NAME=cognee

# Optional: cap how many issues/files we pull (keeps Day 1 fast)
MAX_ISSUES=200
MAX_MDX_FILES=100

# Discord (needed Day 3+)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_HELP_CHANNEL_ID=

# Anthropic — for Claude Code subprocess in Day 2 code_qa
ANTHROPIC_API_KEY=
